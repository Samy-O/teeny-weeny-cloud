# ── Paths ────────────────────────────────────────────────────────────────────
# Local path for app configs and DB data (on server)
DATA_PATH=/opt/teeny-cloud

# NAS mount point (must be pre-mounted on host before starting compose)
NAS_PATH=/mnt/nas

# ── Shared Postgres (Authentik + Joplin) ─────────────────────────────────────
POSTGRES_USER=admin
POSTGRES_PASSWORD=changeme

AUTHENTIK_DB_USER=authentik
AUTHENTIK_DB_NAME=authentik
AUTHENTIK_DB_PASSWORD=changeme

JOPLIN_DB_USER=joplin
JOPLIN_DB_NAME=joplin
JOPLIN_DB_PASSWORD=changeme

# ── Immich Postgres ───────────────────────────────────────────────────────────
IMMICH_DB_USER=immich
IMMICH_DB_NAME=immich
IMMICH_DB_PASSWORD=changeme

# ── Authentik ────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
AUTHENTIK_SECRET_KEY=changeme

# ── Joplin ───────────────────────────────────────────────────────────────────
# Full public URL Joplin clients will use to connect
JOPLIN_BASE_URL=https://joplin.yourdomain.com
